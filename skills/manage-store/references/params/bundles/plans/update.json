{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "bundleId": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "planId": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "name": {
      "type": "string",
      "maxLength": 255
    },
    "prices": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rulesetId": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "description": "Must reference an active ruleset from the same bundle."
          },
          "ranges": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "quantity": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 9007199254740991
                },
                "amount": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "required": [
                "quantity",
                "amount"
              ],
              "additionalProperties": false
            },
            "description": "Required and non-empty. Quantity values must be unique within the ruleset; first quantity should start at 1. Quantity breakpoints should match across all ruleset entries in the same payload."
          }
        },
        "required": [
          "rulesetId",
          "ranges"
        ],
        "additionalProperties": false
      },
      "description": "Prohibited when bundle is configurable without priceType. If sent, must be non-empty and include exactly one entry per active bundle ruleset. Quantity breakpoints must match across rulesets, start at 1, and be unique within each ruleset. May be rejected while plan has active subscribers."
    },
    "discounts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rulesetId": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "description": "Must reference an active ruleset from the same bundle."
          },
          "ranges": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "quantity": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 9007199254740991
                },
                "amountOff": {
                  "anyOf": [
                    {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "percentOff": {
                  "anyOf": [
                    {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 100
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              },
              "required": [
                "quantity"
              ],
              "additionalProperties": false
            },
            "description": "Required and non-empty. Quantity values must be unique within the ruleset; first quantity should start at 1. Quantity breakpoints should match across all ruleset entries in the same payload. Each range should provide amountOff or percentOff (depending on bundle discountType)."
          }
        },
        "required": [
          "rulesetId",
          "ranges"
        ],
        "additionalProperties": false
      },
      "description": "Allowed only when bundle is configurable, has discountType, and has no priceType. If sent, must be non-empty and include exactly one entry per active bundle ruleset. Quantity breakpoints must match across rulesets, start at 1, and be unique within each ruleset. May be rejected while plan has active subscribers."
    },
    "shippings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "addUnit": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "day",
                  "week",
                  "month"
                ]
              },
              {
                "type": "null"
              }
            ],
            "description": "Buffered format: time unit to offset shipment from billing start (day/week/month, limited by frequencyUnit). Mutually exclusive with unitDay/unitOffset. Only available for adhoc billing"
          },
          "addCount": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": -9007199254740991,
                "maximum": 9007199254740991
              },
              {
                "type": "null"
              }
            ],
            "description": "Buffered format: number of addUnit intervals to offset from billing start. Use -1 to ship the day before the next billing cycle. Mutually exclusive with unitDay/unitOffset"
          },
          "unitDay": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": -9007199254740991,
                "maximum": 9007199254740991
              },
              {
                "type": "null"
              }
            ],
            "description": "Anchored format: day within the frequency unit to ship on (1–31 for monthly, 1–7 ISO for weekly). Mutually exclusive with addUnit/addCount. Required for anchored billing or adhoc with anchored shipping"
          },
          "unitOffset": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": -9007199254740991,
                "maximum": 9007199254740991
              },
              {
                "type": "null"
              }
            ],
            "description": "Anchored format: which iteration within the billing period this shipment belongs to (0 to frequencyCount-1). Mutually exclusive with addUnit/addCount"
          }
        },
        "additionalProperties": false
      }
    },
    "cutOffDays": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "cutOffTime": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "chargeImmediately": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "shipImmediately": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "bufferDays": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "trialPrice": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "trialLengthDays": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "trialSingleOrder": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "commitmentBillingCount": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "chargesLimit": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "surveyId": {
      "anyOf": [
        {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "bundleId",
    "planId"
  ],
  "additionalProperties": false
}
