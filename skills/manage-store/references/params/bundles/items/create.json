{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "bundleId": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "variantId": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "quantity": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ],
      "description": "Prohibited when bundle is configurable. For non-configurable bundles: fixed count of this variant included in the bundle."
    },
    "position": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "extraPrice": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ],
      "description": "Prohibited when bundle is not configurable. Additional surcharge in cents added on top of the plan price when a customer selects this item."
    },
    "settings": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "create": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "bundleRulesetId": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "maxQuantity": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 9007199254740991
                  }
                },
                "required": [
                  "bundleRulesetId",
                  "maxQuantity"
                ],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ],
      "description": "Prohibited when bundle is not configurable or is single_product"
    }
  },
  "required": [
    "bundleId",
    "variantId"
  ],
  "additionalProperties": false
}
