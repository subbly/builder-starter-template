{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "slug": {
      "type": "string",
      "maxLength": 70,
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "name": {
      "anyOf": [
        {
          "type": "string",
          "maxLength": 255
        },
        {
          "type": "null"
        }
      ]
    },
    "hiddenItems": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "searchable": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "showRulesetName": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "deliveryInfo": {
      "anyOf": [
        {
          "type": "string",
          "maxLength": 500
        },
        {
          "type": "null"
        }
      ]
    },
    "setupFee": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "preOrderEndAt": {
      "anyOf": [
        {
          "type": "string",
          "format": "date",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))$"
        },
        {
          "type": "null"
        }
      ],
      "description": "Pre-order end date (YYYY-MM-DD). Must be a date after today."
    },
    "giftingEnabled": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "pauseEnabled": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "priceType": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "per_item",
            "total"
          ]
        },
        {
          "type": "null"
        }
      ],
      "description": "Send with discountType/rulesetType updates (null if not needed). Configurable only. Not for single_product or total rulesetType. Mutually exclusive with discountType."
    },
    "discountType": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "per_item",
            "total",
            "percentage"
          ]
        },
        {
          "type": "null"
        }
      ],
      "description": "Send with priceType updates (null if not needed). Configurable only. Mutually exclusive with priceType (except single_product)."
    },
    "rulesetType": {
      "type": "string",
      "enum": [
        "total",
        "quantity"
      ],
      "description": "Configurable only. Not for single_product. Send priceType when updating."
    },
    "appearanceType": {
      "type": "string",
      "enum": [
        "one_step",
        "two_step",
        "without_ruleset"
      ],
      "description": "Configurable only. Not for single_product."
    },
    "quantitySelectors": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "collectShippingAddress": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1,
      "description": "1 = collect shipping address at checkout. Only for digital products. Defaults to 1 for physical products."
    },
    "funnelId": {
      "anyOf": [
        {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "tags": {
      "type": "object",
      "properties": {
        "create": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value": {
                "type": "string",
                "maxLength": 255
              }
            },
            "required": [
              "value"
            ],
            "additionalProperties": false
          }
        },
        "delete": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "id"
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "filters": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "create": {
              "maxItems": 1,
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "metadataId": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": [
                  "metadataId"
                ],
                "additionalProperties": false
              }
            },
            "delete": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "metadataId": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": [
                  "metadataId"
                ],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "preferences": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "create": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "attributeId": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "title": {
                    "type": "string",
                    "maxLength": 255
                  }
                },
                "required": [
                  "attributeId",
                  "title"
                ],
                "additionalProperties": false
              }
            },
            "update": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "title": {
                    "type": "string",
                    "maxLength": 255
                  }
                },
                "required": [
                  "id",
                  "title"
                ],
                "additionalProperties": false
              }
            },
            "delete": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": [
                  "id"
                ],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "rulesets": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "create": {
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "min": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "max": {
                    "anyOf": [
                      {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 9007199254740991
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "name": {
                    "anyOf": [
                      {
                        "type": "string",
                        "maxLength": 255
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "ctaText": {
                    "anyOf": [
                      {
                        "type": "string",
                        "maxLength": 255
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": [
                  "min"
                ],
                "additionalProperties": false
              }
            },
            "update": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "min": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "max": {
                    "anyOf": [
                      {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 9007199254740991
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "name": {
                    "anyOf": [
                      {
                        "type": "string",
                        "maxLength": 255
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "ctaText": {
                    "anyOf": [
                      {
                        "type": "string",
                        "maxLength": 255
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": [
                  "id",
                  "min"
                ],
                "additionalProperties": false
              }
            },
            "delete": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": [
                  "id"
                ],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "images": {
      "type": "object",
      "properties": {
        "create": {
          "maxItems": 5,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "maxLength": 500,
                "format": "uri"
              },
              "order": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "required": [
              "url"
            ],
            "additionalProperties": false
          }
        },
        "delete": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "id"
            ],
            "additionalProperties": false
          }
        },
        "update": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "order": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "id",
              "order"
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "id"
  ],
  "additionalProperties": false
}
